# Mode — keep true until validation matrix passes (100/100)
DRY_RUN=true

# Wallets (never commit real values)
BASE_PRIVATE_KEY=0xYOUR_BASE_PRIVATE_KEY
SOLANA_SECRET_KEY=YOUR_BASE58_SOLANA_SECRET
SOLANA_PUBLIC_KEY=YOUR_SOLANA_PUBLIC_KEY
VNX_PRIVATE_KEY_B64=YOUR_BASE64_PEM_PRIVATE_KEY
VNX_API_PUBLIC_KEY=FROM_VNX_PLATFORM_MY_ACCOUNT

# All arb route groups enabled (Base↔VNX VNXAU + Sol↔VNX CCTP + Base↔Sol)
# Platform-centric treasury — VNXAU lives on VNX; chains hold stables only
VNXAU_ON_CHAIN_DUST=0.01
CLOSE_LOOP_AFTER_CYCLE=true
CLOSE_LOOP_MIN_NET_USD=0
CLOSE_LOOP_FORCE=false
ENABLE_VNX_ARB_ROUTES=true
# SOL ↔ VNX via Circle CCTP (Sol USDC → ETH → platform)
ENABLE_VNX_CCTP_ROUTES=true
INDIRECT_ROUTE_PREMIUM_USD=5

# VNX Platform
VNX_API_BASE=https://api.vnx.li/api/v1
VNX_BASE_WITHDRAW_LABEL=base-hot
VNX_SOL_WITHDRAW_LABEL=sol-hot
VNX_BASE_BLOCKCHAIN=BASE
VNX_SOL_BLOCKCHAIN=SOL
# VNX credits BASE/SOL/ETH on-chain deposits only after cumulative transfers reach this minimum.
VNX_MIN_DEPOSIT_VNXAU_BASE=0.01
VNX_MIN_DEPOSIT_VNXAU_SOL=0.01
VNX_MIN_DEPOSIT_VNXAU_ETH=0.01

# Platform-centric treasury (VNXAU home on VNX; chains hold hub stables only)
PLATFORM_VNXAU_ONLY=true
CLOSE_LOOP_AFTER_CYCLE=true
CLOSE_LOOP_ALWAYS_RETURN=true
JIT_WITHDRAW=true
VNXAU_ON_CHAIN_DUST=0.01

# RPC
RPC_BASE=https://base.llamarpc.com
RPC_SOLANA=https://api.mainnet-beta.solana.com
RPC_ETHEREUM=https://eth.llamarpc.com
VNX_ETH_BLOCKCHAIN=ETH
# VNXAU withdraw label on Ethereum mainnet (defaults to VNX_ETH_WITHDRAW_LABEL)
VNX_ETH_VNXAU_WITHDRAW_LABEL=Arb_Explorer_USDC
# Same hot wallet as BASE (0x13D813…); whitelist on ETH in VNX before live USDC withdraw.
# Often the same destination label as BASE (e.g. Arb_explorer) once ETH is confirmed.
# Must match a Confirmed ETH entry from VNX withdrawAddresses (case-sensitive)
VNX_ETH_WITHDRAW_LABEL=Arb_Explorer_USDC
# VNX credits ETH USDC only after cumulative on-chain transfers reach this minimum.
# Sub-minimum deposits sit pending until cumulative ETH USDC >= min (wallet not credited).
VNX_MIN_DEPOSIT_USDC_ETH=20

# Fund native gas on ETH/SOL/BASE from platform USDC (after ETH whitelist):
#   python scripts/fund_gas.py --amount 10
#
# Convert platform CHF → USDC (min 30 USDC order, ~25 CHF):
#   python scripts/convert_platform_xau.py           # dry-run estimate
#   python scripts/convert_platform_xau.py --execute # live order

# Wormhole claim worker
WORMHOLE_CLAIM_INTERVAL_SEC=30
WORMHOLE_CLAIM_MAX_ROUNDS=120

# Optional
JUPITER_API_KEY=
KYBER_API_URL=https://aggregator-api.kyberswap.com
KYBER_CLIENT_ID=vnxau-menace
# Exclude Kyber limit-order routes (bad ETH VNXAU/USDC fills at ~$10/oz).
KYBER_EXCLUDED_SOURCES=kyberswap-limit-order,kyberswap-limit-order-v2
USE_KYBER_SWAP=true
BASE_SWAP_ROUTER=0x5611CD088a659119948247c7250575A775AAea8b

# Trading limits (deploy: dynamic sizing 0.5–5 VNXAU; platform min order 0.4)
MIN_TRADE_VNXAU=0.5
MAX_TRADE_VNXAU=5
MIN_PROFIT_USD=5
SLIPPAGE_BPS=50
POLL_INTERVAL_SEC=60
QUOTE_CONCURRENCY=1
QUOTE_DELAY_MS=800

# Per-provider minimum spacing between API calls (avoid 429 / bans)
# Jupiter: 1200 with JUPITER_API_KEY (1 RPS free tier), 2500 keyless (0.5 RPS)
API_SYNC_JUPITER_MS=1200
API_SYNC_VNX_MS=1200
API_SYNC_CCTP_MS=1000
API_SYNC_BASE_RPC_MS=400
API_SYNC_DEFAULT_MS=600
# Pause between route groups / sanity agents
API_STAGGER_MS=1500

# Jupiter slippage retry on 6024
# Database
DB_PATH=data/bot.db

# CCTP claim worker poll interval (seconds)
CCTP_CLAIM_INTERVAL_SEC=30
CCTP_CLAIM_MAX_ROUNDS=120
CCTP_IRIS_POLL_SEC=5
CCTP_IRIS_429_BACKOFF_SEC=300
CCTP_IRIS_STAGGER_MS=500
CCTP_INLINE_POLL_SEC=120
CCTP_MAX_STALE_POLLS=24

# VNX bridge polling
VNX_BRIDGE_POLL_SEC=30
VNX_BRIDGE_TIMEOUT_SEC=3600
VNX_QUOTE_RETRY_MAX=5
VNX_ORDER_RETRY_MAX=3
VNX_QUOTE_CACHE_SEC=1.0

# Shared VNX account with GBP/VCHF Menace — retry on platform contention (non-fatal)
VNX_COLLISION_RETRY_MAX=3
VNX_COLLISION_BACKOFF_SEC=5

# RPC / transaction retries
RPC_RETRY_MAX=5
TX_RETRY_MAX=4
API_RETRY_MAX=6
API_RETRY_BACKOFF_BASE_SEC=3.0
API_RETRY_BACKOFF_CAP_SEC=120.0

# Solana RPC — public endpoint is ~2–4 req/s; use a paid RPC in production (Helius, QuickNode, etc.)
# Minimum spacing between any Solana JSON-RPC call (all paths share one throttle)
SOL_RPC_MIN_INTERVAL_MS=800
API_SYNC_SOLANA_RPC_MS=800
# Exponential backoff base on HTTP 429 / rate-limit (doubles each retry, capped by API_RETRY_BACKOFF_CAP_SEC)
SOL_RPC_429_BACKOFF_SEC=8
# Poll interval while waiting for SPL token balance after swap
SOL_BALANCE_POLL_SEC=5
# Max recent signatures scanned per CCTP discover round (each may call getTransaction)
CCTP_DISCOVER_SOL_SIG_LIMIT=8

# Per-provider minimum spacing (ms) — see Circle/Jupiter/VNX docs
API_SYNC_ETH_RPC_MS=250
API_SYNC_BLOCKSCOUT_MS=1000
